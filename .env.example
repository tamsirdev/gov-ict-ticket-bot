# ── Free Mode (works immediately, no API keys needed) ─────────────────
# Just run:  python bot.py
# The app uses rule-based keyword triage and a web UI.
# No environment variables are required.

# ── Paid Upgrades (set these when you have API keys) ──────────────────

# 1. OpenAI — replaces rule-based triage with GPT-3.5
#    Get a key at: https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-...

# 2. Twilio — enables WhatsApp channel (in addition to web UI)
#    Sign up at: https://www.twilio.com/try-twilio
# TWILIO_ACCOUNT_SID=your_account_sid
# TWILIO_AUTH_TOKEN=your_auth_token
